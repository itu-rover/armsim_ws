<?xml version="1.0"?>
<launch>
  <arg name="config" default="true"/>
  <arg name="rviz_config" default="$(find arm26_config)/launch/moveit.rviz"/>

  <!-- RViz -->
  <node name="$(anon rviz)" pkg="rviz" type="rviz" respawn="false"
        args="-d $(arg rviz_config)" output="screen" if="$(arg config)">
  </node>
  <node name="$(anon rviz)" pkg="rviz" type="rviz" respawn="false"
        args="" output="screen" unless="$(arg config)">
  </node>
</launch>
